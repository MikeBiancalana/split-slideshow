# Copy to config.toml and edit. Run: uv run python -m split_slideshow config.toml

[display]
fullscreen = true
# resolution = [1920, 1080]   # omit to use native desktop resolution
background = [0, 0, 0]         # letterbox fill color (RGB)

[slideshow]
interval_seconds = 8          # how long each image shows
stagger_seconds  = 2          # offset between panels so they don't flip in unison
rescan_every     = 20         # re-scan each folder after this many flips (picks up new files)

[panels]
# Exactly 4 folders, one per quadrant: top-left, top-right, bottom-left, bottom-right.
# Subfolders are scanned recursively.
folders = [
  "/home/chadd/Pictures/test1",
  "/home/chadd/Pictures/test2",
  "/home/chadd/Pictures/test3",
  "/home/chadd/Pictures/test4",
]
